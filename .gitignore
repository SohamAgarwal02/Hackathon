# =========================
# Dependencies
# =========================
node_modules/
**/node_modules/

# =========================
# Environment Variables
# =========================
.env
.env.*
**/.env
**/.env.*

# Allow example env files
!.env.example
!**/.env.example

# =========================
# Build folders
# =========================
dist/
build/
dist-ssr/
**/dist/
**/build/
**/dist-ssr/
.vite/
**/.vite/

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# IDE / Editor files
# =========================
.vscode/*
**/.vscode/*
!.vscode/extensions.json
!**/.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.sw?

# =========================
# OS generated files
# =========================
.DS_Store
Thumbs.db

# =========================
# Coverage reports
# =========================
coverage/
**/coverage/

# =========================
# Runtime and temporary files
# =========================
*.pid
*.seed
*.tmp
*.temp
*.local
